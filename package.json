{
  "name": "@danielbriffa/fetchplus",
  "version": "1.0.0",
  "description": "Enhanced fetch API with automatic caching and axios-style interceptors - 100% backward compatible",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev": "vite build --watch",
    "examples": "npm run build && npx vite --port 3000",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fetch",
    "cache",
    "interceptor",
    "axios",
    "http",
    "request",
    "cache-storage",
    "fetch-api"
  ],
  "author": "Daniel Briffa (https://danielbriffa.com)",
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "terser": "^5.36.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danielbriffa/FetchPlus.git"
  },
  "bugs": {
    "url": "https://github.com/danielbriffa/FetchPlus/issues"
  },
  "homepage": "https://github.com/danielbriffa/FetchPlus#readme"
}
